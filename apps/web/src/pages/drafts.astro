---
import BaseLayout from '../layouts/BaseLayout.astro'
---
<BaseLayout title="草稿 — SnowStep">
  <section class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="font-serif text-5xl mb-2">本地草稿</h1>
    <p class="text-ink-mute mb-8">所有保存在浏览器 localStorage 的笔记草稿。点 "继续编辑" 加载到编辑器，点 "删除" 移除本地副本。</p>
    <div id="empty" class="text-ink-mute">还没有草稿。</div>
    <ul id="list" class="space-y-3"></ul>
  </section>
</BaseLayout>
<script>
  const DRAFT_KEY = 'snowstep:drafts'

  function load(): Record<string, { slug: string; body: string; frontmatter: any; savedAt: number }> {
    try {
      return JSON.parse(localStorage.getItem(DRAFT_KEY) || '{}')
    } catch {
      return {}
    }
  }

  function render() {
    const drafts = load()
    const entries = Object.values(drafts).sort((a, b) => b.savedAt - a.savedAt)
    const list = document.getElementById('list') as HTMLUListElement
    const empty = document.getElementById('empty') as HTMLDivElement
    list.innerHTML = ''
    if (entries.length === 0) {
      empty.style.display = 'block'
      return
    }
    empty.style.display = 'none'
    for (const d of entries) {
      const li = document.createElement('li')
      li.className = 'border border-ink/10 rounded-lg p-4 flex items-start justify-between gap-4'
      const date = new Date(d.savedAt).toLocaleString('zh-CN')
      const summary = d.body.replace(/^#+\s*/gm, '').split('\n').filter(Boolean).slice(0, 2).join(' · ').slice(0, 200)
      li.innerHTML = `
        <div class="flex-1 min-w-0">
          <h3 class="font-serif text-xl">${escapeHtml(d.frontmatter.title || '(无标题)')}</h3>
          <p class="text-xs text-ink-mute mt-1">
            <code class="bg-ink/5 px-1 rounded">${escapeHtml(d.slug)}</code>
            · ${d.frontmatter.type === 'clipped' ? '剪藏' : '笔记'}
            · ${d.frontmatter.category?.join(' / ') || ''}
            · ${date}
          </p>
          ${summary ? `<p class="text-sm text-ink-mute mt-2 line-clamp-2">${escapeHtml(summary)}</p>` : ''}
        </div>
        <div class="flex flex-col gap-2 shrink-0">
          <a href="/edit?slug=${encodeURIComponent(d.slug)}" class="px-3 py-1.5 rounded bg-ink text-paper text-xs hover:bg-accent text-center">继续编辑</a>
          <a href="/${encodeURIComponent(d.slug)}" class="px-3 py-1.5 rounded border border-ink/20 text-xs hover:border-accent text-center">查看</a>
          <button data-slug="${escapeHtml(d.slug)}" class="delete-btn px-3 py-1.5 rounded border border-red-300 text-red-700 text-xs hover:bg-red-50">删除</button>
        </div>
      `
      list.appendChild(li)
    }
    list.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const slug = (btn as HTMLElement).dataset.slug!
        if (!confirm(`删除本地草稿 "${slug}" 吗？(不影响 GitHub 上的文件)`)) return
        const drafts = load()
        delete drafts[slug]
        localStorage.setItem(DRAFT_KEY, JSON.stringify(drafts))
        render()
      })
    })
  }

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]!))
  }

  render()
</script>
