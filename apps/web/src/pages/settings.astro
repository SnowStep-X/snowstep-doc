---
import BaseLayout from '../layouts/BaseLayout.astro'
---
<BaseLayout title="设置 — SnowStep">
  <section class="max-w-2xl mx-auto px-6 py-16">
    <h1 class="font-serif text-5xl mb-2">设置</h1>
    <p class="text-ink-mute mb-10">配置 GitHub Personal Access Token，让保存按钮可以直接写回仓库。</p>

    <div class="rounded-lg border border-ink/10 p-6 bg-paper">
      <label for="token-input" class="block font-medium mb-2">GitHub Personal Access Token</label>
      <p class="text-sm text-ink-mute mb-4">
        需要 <code class="bg-ink/5 px-1 rounded">repo</code> 权限。
        <a href="https://github.com/settings/tokens/new?scopes=repo&description=SnowStep" target="_blank" rel="noopener" class="text-accent hover:underline">在这里创建一个</a>。
        Token 仅存于你浏览器的 localStorage，不会上传任何服务器。
      </p>
      <div class="flex gap-2">
        <input
          id="token-input"
          type="password"
          placeholder="ghp_xxxxxxxxxxxxxxxxxxxx"
          class="flex-1 px-3 py-2 border border-ink/20 rounded bg-transparent focus:outline-none focus:border-accent font-mono text-sm"
        />
        <button id="save-token" class="px-4 py-2 rounded bg-ink text-paper text-sm hover:bg-accent transition-colors">保存</button>
        <button id="clear-token" class="px-4 py-2 rounded border border-ink/20 text-sm hover:border-accent transition-colors">清除</button>
      </div>
      <p id="status" class="mt-3 text-sm"></p>
    </div>

    <div class="mt-10 text-sm text-ink-mute">
      <a href="/" class="hover:text-accent">← 回到首页</a>
    </div>
  </section>
</BaseLayout>

<script>
  const input = document.getElementById('token-input') as HTMLInputElement
  const saveBtn = document.getElementById('save-token') as HTMLButtonElement
  const clearBtn = document.getElementById('clear-token') as HTMLButtonElement
  const status = document.getElementById('status') as HTMLParagraphElement

  const STORAGE_KEY = 'snowstep:github_token'

  const existing = localStorage.getItem(STORAGE_KEY)
  if (existing) {
    input.value = existing
    status.textContent = '当前已配置 Token。'
    status.className = 'mt-3 text-sm text-ink-mute'
  }

  saveBtn.addEventListener('click', () => {
    const v = input.value.trim()
    if (!v) {
      status.textContent = 'Token 不能为空。'
      status.className = 'mt-3 text-sm text-red-600'
      return
    }
    if (!v.startsWith('ghp_') && !v.startsWith('github_pat_') && !v.startsWith('ghs_')) {
      status.textContent = 'Token 格式看起来不对（应以 ghp_/github_pat_/ghs_ 开头）。'
      status.className = 'mt-3 text-sm text-red-600'
      return
    }
    localStorage.setItem(STORAGE_KEY, v)
    status.textContent = '已保存到 localStorage。'
    status.className = 'mt-3 text-sm text-green-600'
  })

  clearBtn.addEventListener('click', () => {
    localStorage.removeItem(STORAGE_KEY)
    input.value = ''
    status.textContent = '已清除。'
    status.className = 'mt-3 text-sm text-ink-mute'
  })
</script>
